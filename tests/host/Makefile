# tests/host/Makefile — host-side renderer tests (no devkitARM required).
#
#   make test        build with ASan+UBSan and run   (default for CI/local)
#   make test-nosan  build without sanitizers and run (portability fallback)
#
# Requires source/font_kor.h + source/font_cjk.h to exist (generated by the
# ezflash-kernel-font-generator repo and committed into source/).
#
# test_renderer.c #includes source/draw.c as a single translation unit; the
# fakegba/ directory stands in for libgba and FatFs headers.

CC      ?= cc
CFLAGS  ?= -std=c99 -g -O1 -Wall
INCLUDES = -Ifakegba -I../../source
SAN      = -fsanitize=address,undefined -fno-omit-frame-pointer

DEPS = test_renderer.c \
       ../../source/draw.c \
       ../../source/draw.h \
       ../../source/asc126.h \
       ../../source/font_kor.h \
       ../../source/font_cjk.h \
       fakegba/gba_base.h fakegba/gba_dma.h fakegba/ff.h

test: test_renderer
	./test_renderer

test_renderer: $(DEPS)
	$(CC) $(CFLAGS) $(SAN) $(INCLUDES) -o $@ test_renderer.c

test-nosan: test_renderer_nosan
	./test_renderer_nosan

test_renderer_nosan: $(DEPS)
	$(CC) $(CFLAGS) $(INCLUDES) -o $@ test_renderer.c

clean:
	rm -f test_renderer test_renderer_nosan

.PHONY: test test-nosan clean
